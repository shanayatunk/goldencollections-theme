{% comment %}
  Standard Dawn Announcement Bar Section
  - Renders the announcement bar content
  - Provides settings for text, link, and color scheme
  - Updated schema to use plain text labels instead of translation keys
{% endcomment %}

{%- liquid
  if section.settings.color_scheme == 'background-1' and settings.gradient_background_1 != blank
    assign section_background_gradient = settings.gradient_background_1
  elsif section.settings.color_scheme == 'background-2' and settings.gradient_background_2 != blank
    assign section_background_gradient = settings.gradient_background_2
  elsif section.settings.color_scheme == 'inverse' and settings.gradient_inverse != blank
    assign section_background_gradient = settings.gradient_inverse
  elsif section.settings.color_scheme == 'accent-1' and settings.gradient_accent_1 != blank
    assign section_background_gradient = settings.gradient_accent_1
  elsif section.settings.color_scheme == 'accent-2' and settings.gradient_accent_2 != blank
    assign section_background_gradient = settings.gradient_accent_2
  else
    assign section_background_gradient = nil
  endif
-%}

{%- if section.settings.text != blank -%}
  <div
    class="announcement-bar color-{{ section.settings.color_scheme }} gradient{% if section_background_gradient != blank %} background-gradient{% endif %}"
    role="region"
    aria-label="{{ 'sections.header.announcement' | t: default: 'Announcement' }}" {% comment %} Added fallback for aria-label {% endcomment %}
    {{ section.shopify_attributes }}
  >
    {%- if section.settings.link != blank -%}
      <a href="{{ section.settings.link }}" class="announcement-bar__link link link--text focus-inset animate-arrow">
    {%- endif -%}
    <p class="announcement-bar__message h5">
      {{ section.settings.text | escape }}
      {%- if section.settings.link != blank -%}
        <span class="icon-wrap">{% render 'icon-arrow' %}</span>
      {%- endif -%}
    </p>
    {%- if section.settings.link != blank -%}
      </a>
    {%- endif -%}
  </div>
{%- endif -%}

{% schema %}
{
  "name": "Announcement bar", /* Replaced t: reference */
  "settings": [
    {
      "type": "text",
      "id": "text",
      "default": "Welcome to our store",
      "label": "Text" /* Replaced t: reference */
    },
    {
      "type": "url",
      "id": "link",
      "label": "Link" /* Replaced t: reference */
    },
    {
      "type": "select",
      "id": "color_scheme",
      "options": [
        {
          "value": "accent-1",
          "label": "Accent 1" /* Replaced t: reference */
        },
        {
          "value": "accent-2",
          "label": "Accent 2" /* Replaced t: reference */
        },
        {
          "value": "background-1",
          "label": "Background 1" /* Replaced t: reference */
        },
        {
          "value": "background-2",
          "label": "Background 2" /* Replaced t: reference */
        },
        {
          "value": "inverse",
          "label": "Inverse" /* Replaced t: reference */
        }
      ],
      "default": "accent-1",
      "label": "Color scheme" /* Replaced t: reference */
    }
  ]
}
{% endschema %}

