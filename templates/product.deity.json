{
  "sections": {
    "main": {
      "type": "main-product",
      "blocks": {
        "vendor": {
          "type": "text",
          "disabled": true,
          "settings": {
            "text": "{{ product.vendor }}",
            "text_style": "uppercase"
          }
        },
        "title": {
          "type": "title",
          "settings": {}
        },
        "price": {
          "type": "price",
          "settings": {}
        },
        "deity_fit_summary": {
          "type": "custom_liquid",
          "settings": {
            "custom_liquid": "{% render 'deity-fit-panel', mode: 'compact' %}"
          }
        },
        "variant_picker": {
          "type": "variant_picker",
          "settings": {
            "picker_type": "button",
            "swatch_shape": "circle"
          }
        },
        "quantity_selector": {
          "type": "quantity_selector",
          "settings": {}
        },
        "buy_buttons": {
          "type": "buy_buttons",
          "settings": {
            "show_dynamic_checkout": true,
            "show_gift_card_recipient": false
          }
        },
        "icon_with_text": {
          "type": "icon-with-text",
          "settings": {
            "layout": "horizontal",
            "icon_1": "check_mark",
            "heading_1": "Quality Checked",
            "icon_2": "ruler",
            "heading_2": "Measured Images",
            "icon_3": "chat_bubble",
            "heading_3": "WhatsApp Size Help"
          }
        },
        "deity_fit": {
          "type": "custom_liquid",
          "settings": {
            "custom_liquid": "{% render 'deity-fit-panel' %}"
          }
        },
        "rating": {
          "type": "rating",
          "settings": {}
        },
        "share": {
          "type": "share",
          "settings": {
            "share_label": "Share"
          }
        },
        "description": {
          "type": "description",
          "settings": {}
        }
      },
      "block_order": [
        "vendor",
        "title",
        "price",
        "deity_fit_summary",
        "variant_picker",
        "quantity_selector",
        "buy_buttons",
        "icon_with_text",
        "deity_fit",
        "rating",
        "share",
        "description"
      ],
      "settings": {
        "enable_sticky_info": true,
        "color_scheme": "scheme-1",
        "media_size": "large",
        "constrain_to_viewport": true,
        "media_fit": "contain",
        "gallery_layout": "thumbnail_slider",
        "mobile_thumbnails": "show",
        "media_position": "left",
        "image_zoom": "lightbox",
        "hide_variants": true,
        "enable_video_looping": false,
        "padding_top": 24,
        "padding_bottom": 12
      }
    },
    "deity_story": {
      "type": "deity-product-story",
      "blocks": {
        "short_haram": {
          "type": "link",
          "settings": {
            "title": "Short Haram",
            "collection": "deity-short-harams"
          }
        },
        "long_haram": {
          "type": "link",
          "settings": {
            "title": "Long Haram",
            "collection": "deity-long-harams"
          }
        },
        "earrings": {
          "type": "link",
          "settings": {
            "title": "Earrings",
            "collection": "deity-earrings-for-god-idols-statues"
          }
        },
        "vaddanam": {
          "type": "link",
          "settings": {
            "title": "Vaddanam",
            "collection": "waist-belt-vaddanam-jewellery-for-hindu-gods-goddess-1"
          }
        }
      },
      "block_order": [
        "short_haram",
        "long_haram",
        "earrings",
        "vaddanam"
      ],
      "settings": {
        "cross_sell_heading": "Pair this piece with matching deity ornaments"
      }
    },
    "related-products": {
      "type": "related-products",
      "settings": {
        "heading": "More deity ornaments you may need",
        "heading_size": "h2",
        "products_to_show": 4,
        "columns_desktop": 4,
        "columns_mobile": "2",
        "color_scheme": "scheme-1",
        "image_ratio": "portrait",
        "image_shape": "default",
        "show_secondary_image": true,
        "show_vendor": false,
        "show_rating": false,
        "padding_top": 28,
        "padding_bottom": 32
      }
    }
  },
  "order": [
    "main",
    "deity_story",
    "related-products"
  ]
}
